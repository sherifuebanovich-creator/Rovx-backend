# ── Backend Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────
# DATABASE_URL — pooled connection (via pgbouncer)
# DATABASE_URL_DIRECT — direct connection (for Prisma Migrate)
DATABASE_URL=postgresql://user:password@localhost:5432/rovx_db
DATABASE_URL_DIRECT=

# ── Redis ────────────────────────────────────────────────────────────────
# Supports both URL format and host/port/password format
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ── JWT (REQUIRED — change in production!) ───────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth (REQUIRED for "Sign in with Google" — must match the
# frontend's GOOGLE_CLIENT_ID, used to verify the audience of Google ID
# tokens so a token minted for a different app can't be replayed here) ────
GOOGLE_CLIENT_ID=

# ── CORS (comma-separated origins) ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost

# ── AI (optional — for voice commands, route suggestions, report validation)
OPENAI_API_KEY=
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_VISION_MODEL=llama-3.2-11b-vision-preview

# ── Routing Engine ───────────────────────────────────────────────────────
OSRM_URL=https://router.project-osrm.org

# ── SMTP (required for email verification) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=

# ── Telegram Bot (for report notifications) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_PASSWORD=
# Shared secret Telegram must send back for /telegram/webhook to be accepted.
# If unset, the webhook signature check is skipped entirely — always set this in production.
TELEGRAM_WEBHOOK_SECRET=

# ── Xsolla (for premium subscriptions — https://xsolla.com) ─────────────
XSOLLA_MERCHANT_ID=
XSOLLA_API_KEY=
XSOLLA_PROJECT_ID=
XSOLLA_WEBHOOK_SECRET=
XSOLLA_MODE=sandbox

# ── Manual card payment (Telegram approve/reject flow) ───────────────────
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_HOLDER=
PAYMENT_CARD_BANK=
PAYMENT_AMOUNT=6.49
PAYMENT_CURRENCY=USD

# ── Alternate payment providers (optional, not all in active use) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LAVA_TOP_API_KEY=
LAVA_TOP_OFFER_ID=
LAVA_TOP_WEBHOOK_KEY=
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── App URL (used for Xsolla return_url) ────────────────────────────────
APP_URL=http://localhost:3001
# Backend's own public base URL (used to resolve relative /uploads/... paths
# to absolute URLs, e.g. for AI photo validation).
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── Throttle limits ─────────────────────────────────────────────────────
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_LIMIT=200

# ── Government Data API ──────────────────────────────────────────────────
GOVERNMENT_API_URL=
GOVERNMENT_API_KEY=
GOVERNMENT_DATA_SOURCES=
