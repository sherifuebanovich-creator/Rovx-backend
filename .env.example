# ── Backend Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database (REQUIRED)
# For serverless (Neon/Supabase), also set DATABASE_URL_DIRECT
DATABASE_URL=postgresql://user:password@localhost:5432/rovx_db
DATABASE_URL_DIRECT=

# Redis (REQUIRED — used for refresh tokens, blacklist, rate limiting)
# Format: redis://default:password@host:6379
REDIS_URL=redis://default:your_password@localhost:6379

# JWT (REQUIRED — change in production!)
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost,https://rovx-app-livid.vercel.app

FRONTEND_URL=http://localhost:3000

# AI (optional — for voice commands & route suggestions)
OPENAI_API_KEY=
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Routing Engine
OSRM_URL=https://router.project-osrm.org

# SMTP (required for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=

# Telegram Bot (for report notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Throttle limits
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_LIMIT=200
