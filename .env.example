# ── Backend Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────
# Получите строку подключения в дашборде Neon: Project Settings → Connection Details
# Для продакшена используйте DATABASE_URL_UNPOOLED (рекомендуется Neon)
# DATABASE_URL — пулинг через Neon (pgbouncer)
# DATABASE_URL_DIRECT — прямое подключение (для Prisma Migrate)
#
# Пример строки:
# DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/rovx_db?sslmode=require&pgbouncer=true
# DATABASE_URL_DIRECT=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/rovx_db?sslmode=require
#
DATABASE_URL=postgresql://user:password@localhost:5432/rovx_db
DATABASE_URL_DIRECT=

# Redis (REQUIRED — used for refresh tokens, blacklist, rate limiting)
# Format: redis://default:password@host:6379
REDIS_URL=redis://default:your_password@localhost:6379

# JWT (REQUIRED — change in production!)
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost,https://rovx-app-livid.vercel.app

FRONTEND_URL=http://localhost:3000

# AI (optional — for voice commands & route suggestions)
OPENAI_API_KEY=
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Routing Engine
OSRM_URL=https://router.project-osrm.org

# SMTP (required for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=

# Telegram Bot (for report notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Lava (for premium subscriptions — https://lava.top)
LAVA_API_KEY=
LAVA_OFFER_ID=

# Throttle limits
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_LIMIT=200

# ── Government Data API ──────────────────────────────────────────────────
# Базовый URL для правительственного API открытых данных (камеры/светофоры)
GOVERNMENT_API_URL=
# API ключ для доступа к правительственному API
GOVERNMENT_API_KEY=
# Список источников правительственных данных через запятую (если используется несколько)
GOVERNMENT_DATA_SOURCES=
