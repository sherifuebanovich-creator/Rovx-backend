# ── Backend Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────
# DATABASE_URL — pooled connection (via pgbouncer)
# DATABASE_URL_DIRECT — direct connection (for Prisma Migrate)
DATABASE_URL=postgresql://user:password@localhost:5432/rovx_db
DATABASE_URL_DIRECT=

# ── Redis ────────────────────────────────────────────────────────────────
# Supports both URL format and host/port/password format
REDIS_URL=redis://default:your_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ── JWT (REQUIRED — change in production!) ───────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS (comma-separated origins) ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost

# ── Frontend URL ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── AI (optional — for voice commands, route suggestions, report validation)
OPENAI_API_KEY=
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_VISION_MODEL=llama-3.2-11b-vision-preview

# ── Routing Engine ───────────────────────────────────────────────────────
OSRM_URL=https://router.project-osrm.org

# ── SMTP (required for email verification) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=

# ── Telegram Bot (for report notifications) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_PASSWORD=

# ── Xsolla (for premium subscriptions — https://xsolla.com) ─────────────
XSOLLA_MERCHANT_ID=
XSOLLA_API_KEY=
XSOLLA_PROJECT_ID=
XSOLLA_WEBHOOK_SECRET=
XSOLLA_MODE=sandbox

# ── App URL (used for Xsolla return_url) ────────────────────────────────
APP_URL=http://localhost:3001

# ── Throttle limits ─────────────────────────────────────────────────────
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_LIMIT=200

# ── Government Data API ──────────────────────────────────────────────────
GOVERNMENT_API_URL=
GOVERNMENT_API_KEY=
GOVERNMENT_DATA_SOURCES=
